{% block body %}

	{% if tableaux is empty %}
		<div class="alert alert-warning text-center my-5">
			Aucun tableau ne correspond à votre recherche.
		</div>
	{% else %}
		<div class="d-flex justify-content-center mt-1 mb-5">
			{{ knp_pagination_render(
    tableaux,
    '@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig') }}
		</div>


		<div id="gallery" class="gallery">
			<div class="column"></div>
			<div class="column"></div>
			<div class="column"></div>

			{% for tableau in tableaux %}
				<a href="{{ asset('images/images_sources/' ~ tableau.image) }}" data-id="{{ tableau.id }}" class="gallery-item" data-title="{{ tableau.title }}" data-category="{{ tableau.category }}" data-date="{{ tableau.date|date('d/m/Y') }}" data-commentaires="{{ tableau.commentaires }}" data-description="{{ tableau.description }}" data-keywords="{{ tableau.keywords }}" data-dimension="{{ tableau.dimension }}" data-forsale="{{ tableau.forsale ? 'Oui':'Non' }}" data-aria-label="{{ tableau.ariaLabel }}">
					<img src="{{ asset('images/preview/' ~ tableau.preview) }}" alt="{{ tableau.ariaLabel }}">

					<div class="image-title">
						<div class="overlay"></div>
						<h4>{{ tableau.title }}</h4>
						<p class="mt-3">{{ tableau.category }}</p>
						<p class="mt-0">{{ tableau.date|date('Y') }}</p>
						<span class="oeuvre-link" data-url="{{ path('oeuvre.show', {slug: tableau.slug}) }}">Voir l'œuvre</span>
					</div>
				</a>
			{% endfor %}
		</div>
		<div class="d-flex justify-content-center mt-5 " style="padding-bottom: 3rem;">
			{{ knp_pagination_render(tableaux) }}
		</div>


	{% endif %}
	<!-- ✅ Conteneur de la Lightbox (initialement caché) -->
	<div id="lightbox" class="lightbox">
		<div class="icon-popup">
			<span class="my-close">x</span>
			<!-- Bouton de fermeture -->
			<span class="zoom-icon">+</span>
			<!-- Icône de zoom -->
			<span class="fullscreen-icon">⛶</span>
			<!-- Plein écran -->
			<span class="info-icon">i</span>
			<!-- Information -->
		</div>

		<img id="lightbox-image" src="" alt="">

		<div class="lightbox-details">
			<p id="lightbox-title"></p>
			<p id="lightbox-category"></p>
			<p id="lightbox-date"></p>
			<p id="lightbox-dimension"></p>
			<p id="lightbox-forsale"></p>
			<p id="lightbox-commentaires"></p>
			<p id="lightbox-description"></p>
			<p id="lightbox-keywords"></p>

			<!-- CONTENEUR OÙ INJECTER LE WIDGET COMPLET -->


		</div>
		<div class="lightbox-nav">
			<span class="prev">&#10094;</span>
			<span class="next">&#10095;</span>
		</div>


		<!-- Popup à afficher -->
		<div id="info-popup">
			<span id="close-popup">&times;</span>
			<h3 id="popup-title"></h3>
			<p id="popup-category">
				<span class="label">Catégorie :</span>
				<span class="value"></span>
			</p>
			<p id="popup-date">
				<span class="label">Date de création :</span>
				<span class="value"></span>
			</p>
			<p id="popup-dimension">
				<span class="label">Dimension :</span>
				<span class="value"></span>
			</p>
			<p id="popup-commentaires">
				<span class="label">Commentaires de l'artiste :</span>
				<span class="value"></span>
			</p>
			<p id="popup-description">
				<span class="label">Description :</span>
				<span class="value"></span>
			</p>
			<p id="popup-keywords">
				<span class="label">Mots-Clés :</span>
				<span class="value"></span>
			</p>
			<p id="popup-forsale">
				<span class="label">Disponible à l'acquisition :</span>
				<span class="value"></span>
			</p>
		</div>
		<div id="comments_container"></div>
	</div>


{% endblock %}
