{% extends 'base.html.twig' %}

{% block title %}Tous les tableaux
{% endblock %}

{% block body %}
	<section>
		<div class="header-container">
			<p>
				<a class="btn btn-secondary btn-sm" href="{{ path('admin.tableau.create') }} " style="margin-top: 3rem;">Ajouter un tableau</a>
			</p>
		</div>
		<div class="d-flex justify-content-center mt-4 mb-4">
			{{ knp_pagination_render(tableaux) }}
		</div>

		<div class="row g-4">
			{% for tableau in tableaux %}
				<div class="col-12 col-md-6 col-xl-4">
					<div class="card h-100 shadow">
						<img src="{{ asset('images/preview/' ~ tableau.preview) }}" alt="Preview" class="card-img-top img-fluid" style="object-fit: cover; max-height: 250px;">

						<div class="card-body d-flex flex-column justify-content-between">
							<h5 class="card-title">{{ tableau.title }}</h5>
							<p class="card-text mb-3">
								<strong>N° de tableau :</strong>
								{{ tableau.numeroTableau }}<br>
								<strong>Catégorie :</strong>
								{{ tableau.category.name | default('Non classé') }}
							</p>

							<div class="mt-auto d-flex justify-content-end gap-2">
								<a class="btn btn-light btn-sm" href="{{ path('admin.tableau.edit', {id: tableau.id}) }}">Éditer</a>
								<form action="{{ path('admin.tableau.delete', {id: tableau.id}) }}" method="post" onsubmit="return confirm('Supprimer ce tableau ?')">
									<input type="hidden" value="DELETE">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tableau.id) }}">
									<button type="submit" class="btn btn-secondary btn-sm">Supprimer</button>
								</form>
							</div>
						</div>
					</div>
				</div>
			{% endfor %}
			<div class="col-12 col-md-6 col-xl-4">
				<a href="{{ path('admin.tableau.create') }}" class="text-decoration-none text-dark">
					<div class="card h-100 shadow-sm d-flex align-items-center justify-content-center p-5 text-center border-dashed">
						<div>
							<div class="display-1 fw-bold">+</div>
							<div class="mt-3 fs-5">Ajouter un tableau</div>
						</div>
					</div>
				</a>
			</div>
		</div>

		<div class="d-flex justify-content-center mt-4 mb-4">
			{{ knp_pagination_render(tableaux) }}
		</div>
	</section>

{% endblock %}
