{% extends 'base.html.twig' %}

{% block title %}Contact — Jean-Pierre Navarro, peintre
{% endblock %}

{% block meta_description %}
	<meta name="description" content="Contactez-nous pour une acquisition, une demande de renseignement ou un message à propos des œuvres de Jean-Pierre Navarro.">
{% endblock %}

{% block body %}

	<style>
		html,
		body {
			height: 100%;
			margin: 0;
		}

		/* Image de fond full-screen */
		.contact-hero {
			position: relative;

			/* Full-width "episte" */
			left: 50%;
			right: 50%;
			margin-left: -50vw;
			margin-right: -50vw;
			width: 100vw;

			min-height: 100vh; /* prend toute la hauteur de l'écran */

			background-image: url('{{ asset('images/images_sources/dsc1758-681ccf840bb96963112803.jpg') }}');
			background-position: right top;
			background-repeat: no-repeat;
			background-size: cover;

			display: flex;
			align-items: center; /* centre verticalement le formulaire */
			justify-content: center; /* centre horizontalement */
			padding: 2rem; /* espace autour du formulaire */
			z-index: 0; /* derrière le formulaire */
		}


		/* Bloc formulaire large et spacieux */
		.contact-form {
			position: relative;
			z-index: 2;
			background: rgba(255, 255, 255, 0.25);
			backdrop-filter: blur(10px);
			border-radius: 15px;
			border: 1px solid rgba(255, 255, 255, 0.4);
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
			padding: 3rem 2.5rem; /* plus équilibré */
			width: 100%;
			max-width: 750px;
			color: #222;
			display: flex;
			flex-direction: column;
		}

		.contact-form h2 {
			text-align: center;
			margin-bottom: 2rem;
			font-size: 2rem;
			color: #fff;
			text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
		}

		/* Flex container 2 colonnes */
		.form-grid-2cols {
			display: flex;
			gap: 2rem;
			flex-wrap: nowrap; /* forcer côte à côte */
			align-items: stretch; /* colonnes même hauteur */
		}

		/* Colonnes */
		.left-column {
			flex: 1;
			min-width: 300px;
			display: flex;
			flex-direction: column;
			justify-content: flex-start; /* aligne tout en haut */
		}

		.right-column {
			flex: 1;
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
		}

		/* Le textarea prend toute la hauteur de la colonne */
		.right-column textarea {
			flex: 1; /* occupe toute la hauteur restante */
			min-height: 250px;
		}

		/* Styles uniformes pour inputs, select, textarea */
		input,
		select,
		textarea {
			width: 100%;
			padding: 14px;
			border-radius: 8px;
			border: 1px solid rgba(0, 0, 0, 0.2);
			font-size: 1rem;
			background: rgba(255, 255, 255, 0.85);
			box-sizing: border-box;
		}


		/* Bouton submit */
		.btn-submit {
			background-color: rgba(0, 0, 0, 0.7);
			color: #fff;
			border: none;
			padding: 1rem 1.5rem;
			border-radius: 8px;
			font-weight: 600;
			width: 100%;
			transition: 0.3s;
			margin-top: 1rem;
		}

		.btn-submit:hover {
			background-color: rgba(0, 0, 0, 0.9);
		}

		/* Responsive : mobile full-screen contact form */
		@media(max-width: 768px) {
			.form-grid-2cols {
				flex-direction: column;
				gap: 1rem; /* moins d'espace entre colonnes */
			}

			.left-column,
			.right-column {
				min-width: 0; /* important pour que les colonnes prennent toute la largeur */
				width: 100%; /* remplissage complet */
			}

			.left-column {
				justify-content: center; /* centre verticalement si tu veux */
				gap: 0.75rem; /* espace plus serré entre inputs */
			}

			.right-column textarea {
				min-height: 200px;
				flex: 1;
			}
		}

		/* Très petit écran : encore plus compact */
		@media(max-width: 480px) {
			.contact-form {
				margin-top: 80px;
				padding: 1.5rem 1rem;
				min-height: 85vh;
			}

			.contact-form h2 {
				font-size: 1.5rem;
				margin-bottom: 1rem;
			}

			.left-column,
			.right-column {
				gap: 0.5rem;
			}

			.right-column textarea {
				min-height: 180px;
			}
		}
	</style>

	<div class="contact-hero">
		<div class="contact-form">
			<h2>Écrivez-nous</h2>

			{{ form_start(form, { attr: { 'data-turbo': 'false' } }) }}
			<div class="form-grid-2cols">
				<div class="left-column">
					{{ form_row(form.name, {'label': 'Nom'}) }}
					{{ form_row(form.email, {'label': 'Adresse e-mail'}) }}
					{{ form_row(form.type, {'label': 'Type de demande'}) }}
				</div>
				<div class="right-column">
					{{ form_row(form.message, {'label': 'Message'}) }}
				</div>
			</div>

			<div class="mt-4">
				{{ form_widget(form.save, {'attr': {'class': 'btn-submit'}}) }}
			</div>
			{{ form_end(form) }}

		</div>
	</div>

{% endblock %}
