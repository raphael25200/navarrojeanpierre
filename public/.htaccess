<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirection 301 non-www vers www (canonicalisation)
    RewriteCond %{HTTP_HOST} ^navarrojeanpierre\.com$ [NC]
    RewriteRule ^ https://www.navarrojeanpierre.com%{REQUEST_URI} [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]

</IfModule>
